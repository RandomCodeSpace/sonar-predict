<?xml version="1.0" encoding="UTF-8"?>
<assembly xmlns="http://maven.apache.org/ASSEMBLY/2.2.0"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://maven.apache.org/ASSEMBLY/2.2.0 http://maven.apache.org/xsd/assembly-2.2.0.xsd">
    <id>plugin-dir</id>

    <!--
      Exploded plugin bundle for Claude Code AND GitHub Copilot CLI. Combined
      with finalName=plugin and includeBaseDirectory=true
      (baseDirectory=sonar-predictor), this lands at
      target/plugin/sonar-predictor/ — directly installable as a Claude Code
      plugin (`/plugin install`) or a Copilot CLI plugin (`copilot plugin
      install`). The .claude-plugin/plugin.json format is shared by both
      ecosystems, so one bundle covers both.

      Layout:
        sonar-predictor/
          .claude-plugin/plugin.json       (the shared manifest)
          agents/sonar-scanner.md          (Claude variant — model: haiku)
          agents/sonar-scanner-copilot.md  (Copilot variant — model: gpt-5-mini)
          skills/sonar-predictor/          (the full skill — SKILL.md + bin + lib + plugins)
    -->
    <formats>
        <format>dir</format>
    </formats>

    <baseDirectory>sonar-predictor</baseDirectory>
    <includeBaseDirectory>true</includeBaseDirectory>

    <fileSets>
        <!-- Plugin manifest. -->
        <fileSet>
            <directory>${project.basedir}/src/main/plugin/.claude-plugin</directory>
            <outputDirectory>.claude-plugin</outputDirectory>
            <includes>
                <include>plugin.json</include>
            </includes>
        </fileSet>

        <!-- Agents. The Claude variant lives at the repo's project-agent
             location (.claude/agents/) so it is also available to in-repo
             Claude Code sessions; the Copilot variant lives in this dist
             module's plugin sources. -->
        <fileSet>
            <directory>${project.basedir}/../.claude/agents</directory>
            <outputDirectory>agents</outputDirectory>
            <includes>
                <include>sonar-scanner.md</include>
            </includes>
        </fileSet>
        <fileSet>
            <directory>${project.basedir}/src/main/plugin/agents</directory>
            <outputDirectory>agents</outputDirectory>
            <includes>
                <include>sonar-scanner-copilot.md</include>
            </includes>
        </fileSet>

        <!-- The skill bundle, placed under skills/sonar-predictor/ so the
             plugin auto-discovers it. Same content as the skill.xml assembly,
             rerooted under skills/sonar-predictor/. -->
        <fileSet>
            <directory>${project.basedir}/src/main/skill</directory>
            <outputDirectory>skills/sonar-predictor</outputDirectory>
            <includes>
                <include>SKILL.md</include>
            </includes>
        </fileSet>
        <fileSet>
            <directory>${project.basedir}/src/main/scripts</directory>
            <outputDirectory>skills/sonar-predictor/bin</outputDirectory>
            <includes>
                <include>sonar</include>
            </includes>
            <fileMode>0755</fileMode>
        </fileSet>
        <fileSet>
            <directory>${project.basedir}/src/main/scripts</directory>
            <outputDirectory>skills/sonar-predictor/bin</outputDirectory>
            <includes>
                <include>sonar.bat</include>
            </includes>
            <fileMode>0644</fileMode>
        </fileSet>
        <fileSet>
            <directory>${project.build.directory}/plugins</directory>
            <outputDirectory>skills/sonar-predictor/plugins</outputDirectory>
            <includes>
                <include>*.jar</include>
            </includes>
        </fileSet>
    </fileSets>

    <!-- cli + daemon shaded fat jars, renamed without their version. -->
    <dependencySets>
        <dependencySet>
            <outputDirectory>skills/sonar-predictor/lib</outputDirectory>
            <useProjectArtifact>false</useProjectArtifact>
            <useTransitiveDependencies>false</useTransitiveDependencies>
            <outputFileNameMapping>${artifact.artifactId}.jar</outputFileNameMapping>
            <includes>
                <include>io.github.randomcodespace.sonarpredict:sonar-predictor-cli</include>
                <include>io.github.randomcodespace.sonarpredict:sonar-predictor-daemon</include>
            </includes>
        </dependencySet>
    </dependencySets>
</assembly>
